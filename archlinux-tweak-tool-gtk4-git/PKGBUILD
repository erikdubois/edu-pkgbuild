# Maintainer: Erik Dubois <erik.dubois@gmail.com>
pkgname=archlinux-tweak-tool-gtk4-git
_pkgname=archlinux-tweak-tool-gtk4
_destname1="/usr"
_licensedir="/usr/share/arcolinux/licenses/"
pkgver=26.04
pkgrel=99
pkgdesc="Arch Linux Tweak Tool or ATT"
arch=('x86_64')
url="https://github.com/erikdubois/${_pkgname}"
license=('GPL3')
depends=('xorg-xauth' 'python-gobject' 'polkit-gnome' 'python-distro' 'python-psutil')
optdepends=('alacritty' 'alacritty-themes' 'reflector' 'neofetch' 'chaotic-mirrorlist' 'chaotic-keyring')
makedepends=('git')
options=(!strip !emptydirs)
replaces=(arcolinux-tweak-tool-git)
conflicts=('archlinux-tweak-tool-git' 'arcolinux-tweak-tool-git' 'arcolinux-tweak-tool-dev-git' 'archlinux-tweak-tool-dev-git')
source=("${_pkgname}::git+${url}")
sha256sums=('SKIP')
install='readme.install'
package() {
	install -dm755 "${pkgdir}${_licensedir}${_pkgname}"
	install -m644 "${srcdir}/${_pkgname}/LICENSE" "${pkgdir}${_licensedir}${_pkgname}/LICENSE"
	sed -i "s/pkgversion/$pkgver/" "$srcdir/$_pkgname/usr/share/archlinux-tweak-tool/archlinux-tweak-tool.py"
	sed -i "s/pkgrelease/$pkgrel/" "$srcdir/$_pkgname/usr/share/archlinux-tweak-tool/archlinux-tweak-tool.py"

	cp -r "${srcdir}/${_pkgname}/${_destname1}" "${pkgdir}"
}
