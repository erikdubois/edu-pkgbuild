# Maintainer: Erik Dubois <erik.dubois@gmail.com>
pkgname=ohmychadwm-git
_pkgname=ohmychadwm
_destname1="/etc/skel/.config/"
_destname2="/etc/skel/.bin/"
#_destname3="/usr/share/licenses/dwm/"
#_destname4="/usr/share/man/man1/"
_destname5="/usr/"
_licensedir="/usr/share/edu/licenses/"
pkgver=26.04
pkgrel=120
pkgdesc="Configuration files"
arch=('any')
url="https://github.com/erikdubois/ohmychadwm"
license=('GPL3')
makedepends=(
	'imlib2'
	'make'
	'gcc'
)
depends=(
	'acpi'
	'alacritty'
	'btop'
	'dmenu'
	'edu-rofi-git'
	'edu-rofi-themes-git'
	'feh'
	'gcc'
	'git'
	'imlib2'
	'maim'
	'make'
	'rofi'
	'slock'
	'sxhkd'
	'ttf-jetbrains-mono-nerd'
	'wget'
	'xclip'
	'xorg-server'
	'xorg-xsetroot'
)

optdepends=(
  'fastcompmgr-git: compositor for transparency and effects'
)
provides=("${pkgname}")
options=(!strip !emptydirs)
source=(${_pkgname}::"git+https://github.com/erikdubois/${_pkgname}.git")
sha256sums=('SKIP')
install='readme.install'

build() {
  cd "$srcdir/$_pkgname/etc/skel/.config/ohmychadwm/chadwm"
  make
}

package() {

  cd "$srcdir/$_pkgname/etc/skel/.config/ohmychadwm/chadwm"
  make PREFIX=/usr DESTDIR="$pkgdir" install

	install -dm755 ${pkgdir}${_licensedir}${_pkgname}
	install -m644  ${srcdir}/${_pkgname}/LICENSE ${pkgdir}${_licensedir}${_pkgname}

	install -dm755 ${pkgdir}${_destname1}
	cp -r  ${srcdir}/${_pkgname}${_destname1}* ${pkgdir}${_destname1}

	install -dm755 ${pkgdir}${_destname5}
	cp -r  ${srcdir}/${_pkgname}${_destname5}* ${pkgdir}${_destname5}
}
