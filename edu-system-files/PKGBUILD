# Maintainer: Erik Dubois <erik.dubois@gmail.com>
pkgname=edu-system-files-git
_pkgname=edu-system-files
_destname1="/etc"
_destname2="/usr"
_licensedir="/usr/share/arcolinux/licenses/"
pkgver=26.04
pkgrel=63
pkgdesc="System-wide and user systemfiles (by Erik Dubois)"
arch=('any')
url="https://github.com/erikdubois/${_pkgname}"
license=('GPL3')
depends=('bash')
makedepends=('git')
options=(!strip !emptydirs)
source=("${_pkgname}::git+${url}.git")
sha256sums=('SKIP')

package() {
	install -dm755 "${pkgdir}${_licensedir}${_pkgname}"
	install -m644 "${srcdir}/${_pkgname}/LICENSE" "${pkgdir}${_licensedir}${_pkgname}/LICENSE"
	
	install -dm755 "${pkgdir}${_destname1}"
	cp -r "${srcdir}/${_pkgname}/${_destname1}/." "${pkgdir}${_destname1}/"
	
	install -dm755 "${pkgdir}${_destname2}"
	cp -r "${srcdir}/${_pkgname}/${_destname2}/." "${pkgdir}${_destname2}/"

}
