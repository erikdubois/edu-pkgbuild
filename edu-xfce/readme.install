post_install() {
    echo -e "\n** The files have been installed in /etc/skel/.config/Thunar **"
    echo -e "\n** The files have been installed in /etc/skel/.config/xfce4 **"
    echo -e "\n** The files have been installed in /etc/skel/.config/autostart **"
    echo -e "\n** The files have been installed in /etc/skel/.config/dconf **"
    echo -e "\n** The files have been installed in /etc/skel/.config/plank **\n"
}

post_upgrade() {
    post_install
}
